datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int       @id @default(autoincrement())
  guildId          String
  discordId        String
  points           Int       @default(0)
  level            Int       @default(1)
  currentSeasonExp Int       @default(0)
  totalExp         Int       @default(0)
  isAdmin          Boolean   @default(false)
  lastLoginAt      DateTime?
  streakCount      Int       @default(0)
  totalLogins      Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([guildId, discordId])
  @@map("users")
}

model StoreItem {
  id          Int      @id @default(autoincrement())
  guildId     String
  name        String
  description String?
  price       Int
  roleId      String? // Optional: The Discord Role ID to assign
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("store_items")
}

model GuildConfig {
  id               Int      @id @default(autoincrement())
  guildId          String   @unique
  coinName         String   @default("GEM")
  logChannelId        String? // エラー通知などを送るモデレーター用チャンネル
  textExpLimit        Int      @default(5)
  reactionExpLimit    Int      @default(5)
  referralLoginCount  Int      @default(3)
  referralBonusGem    Int      @default(300)
  referralPassiveRate Float    @default(0.10)
  referralPassiveDays Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("guild_configs")
}

model BonusButton {
  id        String   @id @default(uuid())
  guildId   String
  channelId String
  minReward Int
  maxReward Int
  target    String // 'self' | 'random'
  cost      Int      @default(0) // target が 'random' の場合の消費ポイント
  createdAt DateTime @default(now())

  @@map("bonus_buttons")
}

model BonusClaim {
  id        Int      @id @default(autoincrement())
  guildId   String
  buttonId  String
  discordId String
  claimedAt DateTime @default(now())

  @@map("bonus_claims")
}

model TicketButton {
  id         String   @id @default(uuid())
  guildId    String
  categoryId String? // チャンネル作成先のカテゴリID
  roleIds    String // カンマ区切りのロールID
  createdAt  DateTime @default(now())

  tickets Ticket[]

  @@map("ticket_buttons")
}

model Ticket {
  id        String   @id @default(uuid())
  guildId   String
  channelId String   @unique
  discordId String
  buttonId  String
  createdAt DateTime @default(now())

  button TicketButton @relation(fields: [buttonId], references: [id], onDelete: Cascade)

  @@map("tickets")
}

model StreakConfig {
  id         Int      @id @default(autoincrement())
  guildId    String
  days       Int
  bonusGem   Int?
  roleId     String?
  multiplier Float? // EXPバフ倍率
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([guildId, days])
  @@map("streak_configs")
}

model GuildSeason {
  id           Int      @id @default(autoincrement())
  guildId      String
  seasonNumber Int
  startedAt    DateTime @default(now())
  endedAt      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("guild_seasons")
}

model GuildRoleMultiplier {
  id         Int      @id @default(autoincrement())
  guildId    String
  roleId     String
  multiplier Float
  type       String // 'STREAK' | 'PRIVILEGE'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([guildId, roleId])
  @@map("guild_role_multipliers")
}

model ActionLog {
  id         Int      @id @default(autoincrement())
  guildId    String
  discordId  String
  actionType String // 'TEXT' | 'REACTION'
  targetId   String? // 対象メッセージIDなど（重複防止用）
  createdAt  DateTime @default(now())

  @@index([guildId, discordId, actionType, createdAt])
  @@map("action_logs")
}

model Referral {
  id                 Int       @id @default(autoincrement())
  guildId            String
  parentId           String    // 招待した側（親）
  childId            String    // 招待された側（子）
  inviteCode         String?
  loginCount         Int       @default(0)
  isActive           Boolean   @default(false)
  passiveEndsAt      DateTime?
  totalPassiveEarned Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([guildId, childId])
  @@map("referrals")
}

model BotInvite {
  code      String   @id
  guildId   String
  discordId String
  createdAt DateTime @default(now())

  @@map("bot_invites")
}

model GuildSubscription {
  guildId              String    @id
  plan                 String    @default("FREE") // 'FREE', 'TRIAL', 'PREMIUM'
  purchaseRoute        String?   // 'DISCORD', 'STRIPE'
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  expiresAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@map("guild_subscriptions")
}
